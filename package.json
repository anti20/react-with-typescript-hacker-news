{
    "name": "react-with-typescript-hacker-news",
    "version": "1.0.0",
    "description": "Complete React + TypeScript mini-app with routing and data fetching.",
    "main": "index.js",
    "scripts": {
        "start": "NODE_OPTIONS=--openssl-legacy-provider webpack-dev-server",
        "build": "NODE_ENV='production' webpack",
        "build-for-windows": "SET NODE_ENV='production' && webpack"
    },
    "babel": {
        "presets": [
            "@babel/preset-env",
            "@babel/preset-react",
            "@babel/preset-typescript"
        ],
        "plugins": [
            "@babel/plugin-proposal-class-properties",
            "syntax-dynamic-import"
        ]
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "prop-types": "^15.7.2",
        "query-string": "^6.8.1",
        "react": "^16.8.6",
        "react-dom": "^16.8.6",
        "react-router-dom": "^5.0.1"
    },
    "devDependencies": {
        "@babel/core": "^7.5.5",
        "@babel/plugin-proposal-class-properties": "^7.5.5",
        "@babel/preset-env": "^7.5.5",
        "@babel/preset-react": "^7.0.0",
        "@types/node": "^25.9.1",
        "@types/react": "^16.14.70",
        "@types/react-dom": "^16.9.25",
        "@types/react-router-dom": "^5.3.3",
        "babel-loader": "^8.0.6",
        "babel-plugin-syntax-dynamic-import": "^6.18.0",
        "copy-webpack-plugin": "^5.0.3",
        "css-loader": "^3.1.0",
        "html-webpack-plugin": "^3.2.0",
        "style-loader": "^0.23.1",
        "ts-loader": "^8.4.0",
        "typescript": "^6.0.3",
        "webpack": "^4.36.1",
        "webpack-cli": "^3.3.6",
        "webpack-dev-server": "^3.7.2"
    }
}
